{
  "name": "example-solid",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "run-keycloak": "keycloak-runner -p node_modules/keycloak-onboarding-ui/target/keycloak-onboarding-ui-theme.jar -p node_modules/keycloak-headless-role-created/target/role-created-event-listener.jar --realm master --patch '{ \"adminTheme\": \"keycloak-onboarding-ui\", \"adminEventsEnabled\": true, \"eventsListeners\": [\"headless-role-created\"] }' -- --spi-events-listener--headless-role-created--export-directory=/tmp/keycloak-role-exports",
    "fetch-roles": "fetch-keycloak-roles --url http://localhost:8080 --realm master --username admin --password admin --output /tmp/keycloak-role-exports/master-roles.json"
  },
  "dependencies": {
    "keycloak-headless": "workspace:*",
    "oidc-spa": "^10.2.3",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "keycloak-headless-role-created": "workspace:*",
    "keycloak-onboarding-ui": "0.0.1-preview.0",
    "keycloak-runner": "0.0.1-alpha.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.3",
    "vite-plugin-solid": "^2.11.12"
  }
}
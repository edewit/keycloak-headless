{
  "name": "keycloak-headless",
  "version": "0.0.1",
  "description": "Keycloak headless component library built with Lit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/components/provider/index.d.ts",
      "import": "./dist/components/provider/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "example:react": "pnpm --filter example-react dev",
    "example:vue": "pnpm --filter example-vue dev"
  },
  "keywords": [
    "keycloak",
    "web-components",
    "lit",
    "component-library",
    "vue",
    "svelte",
    "solid-js",
    "react"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.4",
    "jsdom": "^26.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.34"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.8",
    "keycloak-js": "^26.2.4",
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "sideEffects": [
    "./dist/components/**/*.js",
    "./dist/react/**/*.js",
    "./dist/vue/**/*.js",
    "./dist/svelte/**/*.js",
    "./dist/solid/**/*.js"
  ]
}

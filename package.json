{
  "name": "keycloak-headless",
  "version": "0.1.0",
  "description": "Keycloak headless component library built with Lit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/components/provider/index.d.ts",
      "import": "./dist/components/provider/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "keycloak-headless": "./dist/cli/keycloak-headless.js",
    "fetch-keycloak-roles": "./dist/cli/fetch-keycloak-roles.js",
    "create": "./dist/cli/create.js"
  },
  "files": [
    "dist",
    "templates",
    "providers/role-created-event-listener/package.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm sync-templates && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "example:react": "pnpm --filter example-react dev",
    "example:vue": "pnpm --filter example-vue dev",
    "example:solid": "pnpm --filter example-solid dev",
    "example:svelte": "pnpm --filter example-svelte dev",
    "fetch-roles": "tsx src/cli/fetch-keycloak-roles.ts",
    "create-app": "tsx src/cli/create.ts",
    "sync-templates": "tsx scripts/sync-templates.ts",
    "sync-templates:check": "tsx scripts/sync-templates.ts --check"
  },
  "keywords": [
    "keycloak",
    "web-components",
    "lit",
    "component-library",
    "vue",
    "svelte",
    "solid-js",
    "react"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@open-wc/testing": "^4.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.4",
    "jsdom": "^26.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.34"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.3",
    "@keycloak/keycloak-admin-client": "^26.6.3",
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.8",
    "commander": "^15.0.0",
    "oidc-spa": "^10.2.3",
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "sideEffects": [
    "./dist/components/**/*.js",
    "./dist/react/**/*.js",
    "./dist/vue/**/*.js",
    "./dist/svelte/**/*.js",
    "./dist/solid/**/*.js"
  ]
}

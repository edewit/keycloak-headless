{
  "name": "keycloak-headless",
  "version": "1.0.0",
  "description": "Keycloak headless component library built with Lit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/components/provider/index.d.ts",
      "import": "./dist/components/provider/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "example:react": "pnpm --filter example-react dev",
    "example:vue": "pnpm --filter example-vue dev"
  },
  "keywords": [
    "keycloak",
    "web-components",
    "lit",
    "component-library",
    "vue",
    "svelte",
    "solid-js",
    "react"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@eslint/js": "^9.25.1",
    "@vitest/ui": "^3.1.2",
    "eslint": "^9.25.1",
    "jsdom": "^26.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "solid-js": "^1.9.10",
    "svelte": "^5.46.1",
    "vue": "^3.5.13",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.8",
    "keycloak-js": "^26.2.3",
    "lit": "^3.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vue": "^3.4.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "solid-js": "^1.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "sideEffects": [
    "./dist/components/**/*.js",
    "./dist/react/**/*.js",
    "./dist/vue/**/*.js",
    "./dist/svelte/**/*.js",
    "./dist/solid/**/*.js"
  ]
}
